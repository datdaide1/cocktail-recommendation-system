# API Keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-...

# Database Configuration (PostgreSQL Cloud)
# Recommended: Supabase (supabase.com) or Neon (neon.tech)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=5432
# Alternatively, you can use a single connection string:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (Cloud)
# Recommended: Upstash (upstash.com)
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Qdrant (Cloud or Local)
# For local Qdrant: leave QDRANT_URL as http://localhost:6333 and QDRANT_API_KEY empty
# For Qdrant Cloud: replace with your cluster URL and API key
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
