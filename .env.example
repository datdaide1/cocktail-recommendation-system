# -----------------------------------------------------------------------------
# AI Cocktail Assistant Configuration
# -----------------------------------------------------------------------------

# LLM Provider: 'gemini', 'openai', 'openrouter', or 'custom' (Leave blank for auto-detection)
LLM_PROVIDER=gemini

# Custom API Config (Beeknoee / 9router)
CUSTOM_API_KEY=your_custom_api_key_here
CUSTOM_API_BASE=http://127.0.0.1:20128/v1
CUSTOM_MODEL=beeknoee/gemini-3.5-flash

# Google Gemini API Config
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# OpenAI API Config
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter API Config
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Embedding Model Name (Local SentenceTransformer)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# App settings
PORT=8501
HOST=localhost
